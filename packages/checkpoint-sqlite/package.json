    "@langchain/langgraph": "^1.4.7"
  },
  "devDependencies": {
    "@veloxdevworks/flowgraph-core": "workspace:*",
    "@langchain/langgraph": "^1.4.7",
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
