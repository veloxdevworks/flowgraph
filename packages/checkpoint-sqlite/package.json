{
  "name": "@veloxdevworks/flowgraph-checkpoint-sqlite",
  "version": "0.1.0",
  "description": "Durable SQLite checkpointer for flowgraph",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
