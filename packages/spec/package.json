{
  "name": "@veloxdevworks/flowgraph-spec",
  "version": "0.1.0",
  "description": "Zod schemas and JSON Schema for the flowgraph YAML graph specification",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
